---
import Glow from './Glow.astro';
---

<div class="relative flex overflow-hidden pt-30 gap-8 items-start" id="preview">

  <!--Seccion de barra de opciones glass efect -->
  <div class="bg-white/40 backdrop-blur-md border border-white/50 rounded-2xl w-72 p-4 shadow-lg shrink-0">
    <ul class="flex flex-col gap-2">
      <li class="list-item selected rounded-xl bg-white text-green-600 px-4 py-3 font-medium transition-all duration-300 cursor-pointer" data-img="/preview1.png">
        <div class="flex items-center gap-3">
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="12" y1="7" x2="5" y2="17"/><line x1="12" y1="7" x2="19" y2="17"/></svg>
          <span>Diagrama peticiones</span>
        </div>
      </li>
      <li class="list-item rounded-xl px-4 py-3 font-medium text-gray-700 transition-all duration-300 cursor-pointer hover:bg-white/70 hover:text-green-600" data-img="/preview2.png">
        <div class="flex items-center gap-3">
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          <span>Generar API's de prueba</span>
        </div>
      </li>
      <li class="list-item rounded-xl px-4 py-3 font-medium text-gray-700 transition-all duration-300 cursor-pointer hover:bg-white/70 hover:text-green-600" data-img="/preview3.png">
        <div class="flex items-center gap-3">
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <span>Detectar y exportar repositorios</span>
        </div>
      </li>
    </ul>
  </div>

  <!--Seccion de imagenes por cada opcion que se eliga -->
  <div class="flex-1 flex items-start justify-center">
    <div class="relative w-full max-w-3xl overflow-hidden rounded-2xl shadow-lg">
      <Glow />
      <img id="preview-img" src="/preview1.png" alt="Preview" class="w-full transition-opacity duration-500 ease-in-out relative" />
    </div>
  </div>
</div>

<script>
  const img = document.getElementById('preview-img');

  document.querySelectorAll('.list-item').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.list-item').forEach(i => {
        i.classList.remove('bg-white', 'text-green-600');
        i.classList.add('text-gray-700', 'hover:bg-white/70', 'hover:text-green-600');
      });
      el.classList.add('bg-white', 'text-green-600');
      el.classList.remove('text-gray-700', 'hover:bg-white/70', 'hover:text-green-600');

      // Cambiar imagen con fade
      img.style.opacity = '0';
      setTimeout(() => {
        img.src = el.dataset.img;
        img.style.opacity = '1';
      }, 250);
    });
  });
</script>
