<section class="relative py-32 px-6" id="preview">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-100">
        Mira cómo funciona
      </h2>
      <p class="mt-4 text-zinc-400 max-w-xl mx-auto">
        Cada vista te muestra una parte distinta de lo que GReq puede hacer por ti.
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <div class="w-full lg:w-72 shrink-0 bg-zinc-900/50 backdrop-blur-sm border border-zinc-800 rounded-2xl p-2 shadow-lg">
        <ul class="flex flex-col gap-1">
          <li class="list-item selected rounded-xl bg-emerald-500/10 text-emerald-400 px-4 py-3 font-medium transition-all duration-300 cursor-pointer" data-img="/preview1.png">
            <div class="flex items-center gap-3">
              <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="12" y1="7" x2="5" y2="17"/><line x1="12" y1="7" x2="19" y2="17"/></svg>
              <span>Diagrama peticiones</span>
            </div>
          </li>
          <li class="list-item rounded-xl px-4 py-3 font-medium text-zinc-400 transition-all duration-300 cursor-pointer hover:bg-zinc-800/50 hover:text-emerald-400" data-img="/preview2.png">
            <div class="flex items-center gap-3">
              <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
              <span>Generar APIs de prueba</span>
            </div>
          </li>
          <li class="list-item rounded-xl px-4 py-3 font-medium text-zinc-400 transition-all duration-300 cursor-pointer hover:bg-zinc-800/50 hover:text-emerald-400" data-img="/preview3.png">
            <div class="flex items-center gap-3">
              <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              <span>Detectar y exportar repositorios</span>
            </div>
          </li>
        </ul>
      </div>

      <div class="flex-1">
        <div class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900/30 shadow-2xl">
          <img id="preview-img" src="/preview1.png" alt="Preview" class="w-full transition-opacity duration-500 ease-in-out" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const img = document.getElementById('preview-img') as HTMLImageElement | null;

  document.querySelectorAll('.list-item').forEach(el => {
    el.addEventListener('click', () => {
      document.querySelectorAll('.list-item').forEach(i => {
        i.classList.remove('selected', 'bg-emerald-500/10', 'text-emerald-400');
        i.classList.add('text-zinc-400');
      });
      el.classList.add('selected', 'bg-emerald-500/10', 'text-emerald-400');
      el.classList.remove('text-zinc-400');

      if (!img) return;
      img.style.opacity = '0';
      setTimeout(() => {
        img.src = (el as HTMLElement).dataset.img || '';
        img.style.opacity = '1';
      }, 250);
    });
  });
</script>
