<script>
  const target = document.getElementById('typewriter-target')!;
    const text = 'Todo en un solo lugar. Diseña visualmente, genera APIs de prueba, y exporta tu documentación — sin complicaciones.';
    let i = 0;
    function type() {
      if (i < text.length) {
        target.textContent += text.charAt(i);
        i++;
        setTimeout(type, 18 + Math.random() * 22);
      }
    }
    setTimeout(type, 1100);
</script>
